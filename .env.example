# ===========================================
# Knowledge Base MVP - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# OpenAI API Key (required for embeddings and agents)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge_base_2024

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Repository Paths — absolute, or relative to the knowledge-base/ folder (not your shell CWD)
# Example when orbit/ and trinity-v2/ sit next to knowledge-base/ on Desktop:
ORBIT_REPO_PATH=../orbit
TRINITY_REPO_PATH=../trinity-v2

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM Model for Agents
LLM_MODEL=gpt-4o

# Optional: Logging
LOG_LEVEL=INFO

# ============================================
# Feature Builder — GitHub Integration
# ============================================
# Personal Access Token with repo scope (required for push + PR creation)
GITHUB_TOKEN=ghp_your_token_here

# GitHub organisation / repo slugs
GITHUB_ORG=PlumHQ
ORBIT_REPO_GITHUB=PlumHQ/orbit
TRINITY_REPO_GITHUB=PlumHQ/trinity-v2

# Feature branch prefix (branches will be named: kb/feature/<slug>)
FEATURE_BRANCH_PREFIX=kb/feature

# Safety: refuse to modify more than this many files per repo in one run
MAX_FILES_PER_REPO=15

# Set to false ONLY when you are ready to write code and push branches
DRY_RUN_DEFAULT=true
